  "test_case_6_fair_housing_violations": {
    "name": "Test Case 6 - Fair Housing Compliance",
    "scenario": "Copywriter catches Fair Housing violations in generated copy",
    "campaign_brief": {
      "target_floorplan": "2br",
      "persona": "family",
      "emotional_lever": "family_friendly",
      "messaging_direction": "Focus on quality of life for growing families"
    },
    "test_violations": [
      {
        "violation_id": "v-001",
        "text": "Perfect for families with young children - safe family neighborhood",
        "violation_type": "Familial Status",
        "severity": "CRITICAL",
        "reason": "Cannot advertise as 'perfect for families' - implies familial status preference"
      },
      {
        "violation_id": "v-002",
        "text": "Great for professionals who value success",
        "violation_type": "National Origin / Occupation Targeting",
        "severity": "CRITICAL",
        "reason": "Cannot target 'professionals' - implies socioeconomic/occupation preferences"
      },
      {
        "violation_id": "v-003",
        "text": "Located in the best ethnic neighborhood",
        "violation_type": "National Origin / Race",
        "severity": "CRITICAL",
        "reason": "Cannot mention ethnicity of neighborhood - fair housing violation"
      }
    ],
    "expected_output": {
      "fair_housing_violations": 3,
      "blocks_human_approval": true,
      "reason": "Cannot proceed to human_approval when violations present",
      "copywriter_action": "Return to copywriter for regeneration without violations",
      "compliant_rewrites": [
        "Perfect for renters seeking a vibrant, walkable community",
        "Great for renters who value career development and community",
        "Located in a dynamic neighborhood with diverse dining and entertainment"
      ]
    }
  },
  "test_case_7_hitl_feedback_loop": {
    "name": "Test Case 7 - HITL Feedback & Regeneration",
    "scenario": "Human approver requests visual regeneration - feedback loop back to visual_creator",
    "human_approval_request": {
      "approval_status": "regenerate_visuals",
      "editor_notes": "The 3BR carousel needs warmer colors - these feel too modern/cold for family positioning. Also, the video script seems too fast-paced for the family audience. Can we make it more warm and inviting?",
      "briefs_approved": 0,
      "reviewer_name": "Sarah Chen",
      "review_timestamp": "2026-05-25T14:32:00Z"
    },
    "expected_flow": {
      "routing": "human_approval → visual_creator (feedback loop)",
      "visual_creator_receives": {
        "editor_notes": "warmer colors, more inviting, slower pacing",
        "target_brief": "3BR family-focused campaign",
        "regenerate_visual_tone": "warm_cozy instead of modern_sleek",
        "video_pacing": "slower, more deliberate transitions"
      },
      "visual_creator_returns": "New visual packages with warm tones, family-oriented imagery",
      "next_step": "Back to human_approval for re-review"
    }
  },
